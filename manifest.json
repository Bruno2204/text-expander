{
  "manifest_version": 3,
  "name": "Text Expander",
  "description": "Expande atajos de texto automáticamente en cualquier campo de texto. Ideal para plataformas de chat como Respond.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["shortcuts.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
